# ============================================
# GameVault — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.

# ── Supabase ──────────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Authentication ────────────────────────────
# Used for API JWT signing (generate a strong random string)
JWT_SECRET=generate-a-strong-random-secret-here
NEXTAUTH_SECRET=generate-a-strong-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Twitch OAuth ──────────────────────────────
# Get from: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# ── Game Metadata APIs ────────────────────────
# RAWG: https://rawg.io/apidocs (free tier: 20,000 requests/month)
RAWG_API_KEY=your-rawg-api-key

# IGDB (via Twitch): https://api-docs.igdb.com/
IGDB_CLIENT_ID=your-igdb-client-id
IGDB_CLIENT_SECRET=your-igdb-client-secret

# RetroAchievements: https://retroachievements.org/APIDemo.php
RETRO_ACHIEVEMENTS_API_KEY=your-retro-achievements-api-key
RETRO_ACHIEVEMENTS_USERNAME=your-username

# ── Epic Games Store ──────────────────────────
# Get from: https://dev.epicgames.com/portal
EPIC_CLIENT_ID=your-epic-client-id
EPIC_CLIENT_SECRET=your-epic-client-secret

# ── Steam (optional) ─────────────────────────
# Get from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# ── Server Configuration ─────────────────────
API_PORT=3001
API_URL=http://localhost:3001
WEB_PORT=3000
NODE_ENV=development
NEXT_PUBLIC_STEAM_ENABLED=false

# ── Database ──────────────────────────────────
# For production (Supabase Postgres):
# DATABASE_URL="postgres://user:password@host:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgres://user:password@host:5432/postgres"

# For local development (SQLite):
DATABASE_LOCAL_URL="file:./database/gamevault.db"
