generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/prisma-client-desktop"
}

generator api {
  provider = "prisma-client-js"
  output   = "../node_modules/prisma-client-api"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_LOCAL_URL")
}

model User {
  id            String   @id @default(cuid())
  supabaseId    String?  @unique
  email         String   @unique
  username      String
  passwordHash  String?
  avatarUrl     String?
  steamId       String?
  provider      String   @default("SUPABASE")
  providerId    String?
  createdAt     DateTime @default(now())
  games         UserGame[]
  sessions      PlaySession[]
  achievements  UserAchievement[]
  gameAchievements GameAchievement[]
  badges        UserBadge[]
  challenges    UserChallenge[]
  challengeProgress ChallengeProgress[]
  friends       Friend[] @relation("UserToFriend")
  friendedBy    Friend[] @relation("FriendToUser")
  activities    Activity[]
  messages      Message[]
  bugReports    BugReport[]
}

model Friend {
  id          String   @id @default(cuid())
  userId      String
  friendId    String
  status      String   @default("PENDING") // PENDING, ACCEPTED, BLOCKED
  createdAt   DateTime @default(now())
  user        User     @relation("UserToFriend", fields: [userId], references: [id])
  friend      User     @relation("FriendToUser", fields: [friendId], references: [id])

  @@unique([userId, friendId])
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String   // STARTED_PLAYING, EARNED_ACHIEVEMENT, ADDED_GAME
  gameId      String?
  metadata    String?  // JSON string for additional info
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Game {
  id           String   @id @default(cuid())
  title        String
  slug         String?  @unique
  exePath      String?  @unique
  processName  String?
  coverUrl     String?
  igdbId       String?
  rawgId       String?
  platform     String   @default("PC")
  genre        String?
  developer    String?
  publisher    String?
  launchUri    String?
  steamAppId   Int?     @unique
  epicAppId    String?  @unique
  gogAppId     Int?     @unique
  source       String   @default("manual")
  rating       Float?
  description  String?
  createdAt    DateTime @default(now())
  userGames    UserGame[]
  sessions     PlaySession[]
  achievements Achievement[]
  gameAchievements GameAchievement[]
  communityAchievements CommunityAchievement[]
}

model CommunityAchievement {
  id          String   @id @default(cuid())
  gameId      String
  key         String
  title       String
  description String
  iconUrl     String?
  createdAt   DateTime @default(now())
  game        Game     @relation(fields: [gameId], references: [id])
  @@unique([gameId, key])
}

model UserGame {
  id            String   @id @default(cuid())
  userId        String
  gameId        String
  status        String   @default("playing")
  totalPlaytime Int      @default(0)
  lastPlayed    DateTime?
  lastPlayedAt  DateTime?
  rating        Int?
  isFavorite    Boolean  @default(false)
  processName   String?
  notes         String?
  user          User     @relation(fields: [userId], references: [id])
  game          Game     @relation(fields: [gameId], references: [id])
  playSessions  PlaySession[]
  externalLinks ExternalLink[]
  userAchievements UserAchievement[]
  
  // New Feedback Fields
  is100Percent  Boolean  @default(false)
  wouldReplay   Boolean  @default(false)
  
  @@unique([userId, gameId])
}

model Message {
  id          String   @id @default(cuid())
  userId      String
  content     String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model BugReport {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  category    String   // UI, TRACKER, API, OTHER
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model ExternalLink {
  id          String   @id @default(cuid())
  userGameId  String
  url         String
  label       String
  tag         String   @default("OTHER")
  userGame    UserGame @relation(fields: [userGameId], references: [id])
}

model PlaySession {
  id            String   @id @default(cuid())
  userId        String
  gameId        String
  userGameId    String?
  startTime     DateTime
  endTime       DateTime?
  lastHeartbeat DateTime?
  duration      Int      @default(0)
  exitStatus    String   @default("UNKNOWN") // NORMAL, CRASH, FORCE_KILLED, VAULT_CLOSED, UNKNOWN
  synced        Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id])
  game          Game     @relation(fields: [gameId], references: [id])
  userGame      UserGame? @relation(fields: [userGameId], references: [id])
}

model Achievement {
  id          String   @id @default(cuid())
  gameId      String
  key         String
  title       String
  description String
  iconUrl     String?
  condition   String
  game        Game     @relation(fields: [gameId], references: [id])
  earned      UserAchievement[]
  @@unique([gameId, key])
}

model GameAchievement {
  id          String    @id @default(uuid())
  userId      String
  gameId      String
  key         String
  name        String
  description String?
  iconUrl     String?
  isEarned    Boolean   @default(false)
  earnedAt    DateTime?
  source      String    @default("steam")
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  game        Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  @@unique([userId, gameId, key])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId      String
  achievementId String
  userGameId    String?
  earnedAt      DateTime @default(now())
  unlockedAt    DateTime?
  progress      Int      @default(100)
  synced        Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  userGame      UserGame? @relation(fields: [userGameId], references: [id])
  @@unique([userId, achievementId])
}

model Badge {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  description      String
  icon             String   // Icon identifier (e.g. lucide icon name or emoji)
  color            String?
  rarity           String   // COMMON, RARE, EPIC, LEGENDARY
  conditionType    String   // TOTAL_PLAYTIME, SESSION_PLAYTIME, LIBRARY_COUNT, ACHIEVEMENT_COUNT, STREAK_DAYS, etc.
  conditionValue   Int
  createdAt        DateTime @default(now())
  users            UserBadge[]
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeId     String
  unlockedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  badge       Badge    @relation(fields: [badgeId], references: [id])
  @@unique([userId, badgeId])
}

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   // PLAYTIME, ACHIEVEMENTS, GAMES_LAUNCHED, STREAK
  category    String   // DAILY, WEEKLY, MILESTONE, STREAK
  targetValue Int
  createdAt   DateTime @default(now())
  userChallenges UserChallenge[]
}

model UserChallenge {
  id              String   @id @default(cuid())
  userId          String
  challengeId     String
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED
  currentProgress Int      @default(0)
  completedAt     DateTime?
  streakCount     Int      @default(0)
  lastUpdated     DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
  challenge       Challenge @relation(fields: [challengeId], references: [id])
  @@unique([userId, challengeId])
}

model ChallengeProgress {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  date        DateTime // For daily/weekly resets
  value       Int      @default(0)
  user        User     @relation(fields: [userId], references: [id])
  @@unique([userId, challengeId, date])
}
