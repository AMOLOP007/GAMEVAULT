{
  "name": "gamevault",
  "version": "1.4.6",
  "private": true,
  "description": "GameVault – Universal Game Tracker & Library Manager",
  "main": "apps/desktop/dist/main/index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "cross-env NODE_OPTIONS=\"--max-old-space-size=512\" npm run dev --workspace=apps/api",
    "dev:web": "cross-env NODE_OPTIONS=\"--max-old-space-size=1024\" npm run dev --workspace=apps/web",
    "enforce-size": "powershell.exe -ExecutionPolicy Bypass -File ./scripts/enforcer.ps1",
    "dev:desktop": "concurrently -k -p \"[{name}]\" -n \"WEB,API,DESK,ENFORCER\" -c \"magenta,cyan,blue,red\" \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:desktop-only\" \"npm run enforce-size\"",
    "dev:lite": "concurrently -k -p \"[{name}]\" -n \"API,DESK,ENFORCER\" -c \"cyan,blue,red\" \"npm run dev:api\" \"npm run dev:desktop-only\" \"npm run enforce-size\"",
    "dev:desktop-only": "npm run dev --workspace=apps/desktop",
    "package": "npm run build:all && electron-builder --config electron-builder.config.js",
    "build:all": "npm run build:api && npm run build:web && npm run build:desktop",
    "build:production": "npm run build:all && electron-builder --config electron-builder.config.js",
    "build:clean": "rimraf apps/web/.next apps/api/dist apps/desktop/dist D:/GAMEVAULT-dist",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "db:generate": "npx prisma generate --schema=database/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=database/schema.prisma",
    "db:push": "npx prisma db push --schema=database/schema.prisma",
    "db:seed": "npx tsx database/seed.ts",
    "db:studio": "npx prisma studio --schema=database/schema.prisma",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0"
  }
}
